import numpy as np
import pandas as pd
from sklearn.model_selection import GroupShuffleSplit
from sklearn.base import clone
from sklearn.metrics import mean_absolute_error, mean_squared_error, median_absolute_error, r2_score

def _metrics(y_true, y_pred):
    return {
        "R2": float(r2_score(y_true, y_pred)),
        "MAE": float(mean_absolute_error(y_true, y_pred)),
        "RMSE": float(np.sqrt(mean_squared_error(y_true, y_pred))),
        "MedAE": float(median_absolute_error(y_true, y_pred)),
    }

def run_group_splits_ratios(
    X, y, groups, models_dict,
    test_sizes=(0.2, 0.3, 0.4, 0.1),
    seeds=range(1, 51),
    log_target=True,
    label="SplitRatios_GroupShuffle"
):
    rows = []

    for ts in test_sizes:
        for seed in seeds:
            splitter = GroupShuffleSplit(n_splits=1, test_size=ts, random_state=seed)
            tr_idx, te_idx = next(splitter.split(X, y, groups=groups))

            X_tr, X_te = X.iloc[tr_idx], X.iloc[te_idx]
            y_tr, y_te = y.iloc[tr_idx], y.iloc[te_idx]

            # baseline (
            baseline_pred = np.full_like(y_te.values, y_tr.mean(), dtype=float)
            baseline_mae = float(mean_absolute_error(y_te.values, baseline_pred))
            baseline_rmse = float(np.sqrt(mean_squared_error(y_te.values, baseline_pred)))

            for name, model in models_dict.items():
                m = clone(model)

                # TRAIN
                y_fit = np.log1p(y_tr.values) if log_target else y_tr.values
                m.fit(X_tr, y_fit)

                # PRED
                y_pred = m.predict(X_te)
                if log_target:
                    y_pred = np.expm1(y_pred)
                    y_pred = np.clip(y_pred, 0, None)

                met = _metrics(y_te.values, y_pred)

                skill_mae = float(1.0 - met["MAE"] / baseline_mae) if baseline_mae > 0 else np.nan
                skill_rmse = float(1.0 - met["RMSE"] / baseline_rmse) if baseline_rmse > 0 else np.nan

                rows.append({
                    "Label": label,
                    "Model": name,
                    "test_size": float(ts),
                    "seed": int(seed),
                    "n_groups_total": int(groups.nunique()),
                    "n_groups_train": int(groups.iloc[tr_idx].nunique()),
                    "n_groups_test": int(groups.iloc[te_idx].nunique()),
                    "Test_R2": met["R2"],
                    "Test_MAE": met["MAE"],
                    "Test_RMSE": met["RMSE"],
                    "Test_MedAE": met["MedAE"],
                    "Baseline_MAE": baseline_mae,
                    "Baseline_RMSE": baseline_rmse,
                    "Skill_MAE": skill_mae,
                    "Skill_RMSE": skill_rmse,
                    "log_target": bool(log_target),
                })

    df_all = pd.DataFrame(rows)

    n_rep = len(list(seeds))
    df_sum = (
        df_all.groupby(["Label", "Model", "test_size", "log_target"])
        .agg(
            Test_R2_mean=("Test_R2","mean"), Test_R2_std=("Test_R2","std"),
            Test_MAE_mean=("Test_MAE","mean"), Test_MAE_std=("Test_MAE","std"),
            Test_RMSE_mean=("Test_RMSE","mean"), Test_RMSE_std=("Test_RMSE","std"),
            Test_MedAE_mean=("Test_MedAE","mean"), Test_MedAE_std=("Test_MedAE","std"),
            Baseline_RMSE_mean=("Baseline_RMSE","mean"),
            Skill_RMSE_mean=("Skill_RMSE","mean"), Skill_RMSE_std=("Skill_RMSE","std"),
            n_groups_test_mean=("n_groups_test","mean"),
        )
        .reset_index()
    )

    # IC95
    df_sum["Test_RMSE_CI95"]  = 1.96 * df_sum["Test_RMSE_std"]  / np.sqrt(n_rep)
    df_sum["Skill_RMSE_CI95"] = 1.96 * df_sum["Skill_RMSE_std"] / np.sqrt(n_rep)

    return df_all, df_sum




