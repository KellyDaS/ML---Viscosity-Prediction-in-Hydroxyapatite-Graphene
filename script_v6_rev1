def rmse(y_true, y_pred):
    return float(np.sqrt(mean_squared_error(y_true, y_pred)))

def cv_objective_rmse_originalscale(model, X, y, groups):
    """
    Treina em log1p(y) e avalia RMSE na escala original (expm1).
    Retorna RMSE médio nos folds.
    """
    rmses = []
    for tr_idx, te_idx in gkf.split(X, y, groups):
        Xtr, Xte = X.iloc[tr_idx], X.iloc[te_idx]
        ytr, yte = y.iloc[tr_idx], y.iloc[te_idx]

        model.fit(Xtr, np.log1p(ytr.values))
        pred_log = model.predict(Xte)
        pred = np.expm1(pred_log)
        pred = np.clip(pred, 0, None)

        rmses.append(rmse(yte.values, pred))
    return float(np.mean(rmses))

