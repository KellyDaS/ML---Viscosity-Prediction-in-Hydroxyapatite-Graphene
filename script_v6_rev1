import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from scipy.optimize import curve_fit
from pathlib import Path
import math

# ============================================================
# CONFIG
# ============================================================
OUTDIR = Path("FIG_PAPER_LINEAR_ALL7_SAMESCALE")
OUTDIR.mkdir(exist_ok=True)

