            out.append(d)
            continue

        p0 = [max(0.0, np.min(tau)), 1.0, 0.5]
        popt, _ = curve_fit(herschel_bulkley, gamma, tau, p0=p0, bounds=bounds, maxfev=20000)
        tau0, K, n = map(float, popt)

        d["tau_0"] = tau0
        d["K"] = K
        d["n"] = n
        out.append(d)

    df_out = pd.concat(out, ignore_index=True)
    df_measured = df_out[df_out["MEASURED"]].copy()
    return df_measured

