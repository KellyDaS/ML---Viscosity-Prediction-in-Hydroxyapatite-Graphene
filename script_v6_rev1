# ── 6. Aggregate Optimal Parameters for ST3 and ST4 ───────────
# Function to get optimal parameter from processed folds (median for numerical, mode for categorical)
def get_optimal_from_folds(df_folds, model_name, param_name, ptype):
    if df_folds.empty or model_name not in df_folds['Model'].unique() or param_name not in df_folds.columns:
        return np.nan

    model_folds = df_folds[df_folds['Model'] == model_name]
    if model_folds.empty:
        return np.nan

    if ptype == "categorical":
        # Use mode for categorical, handle multiple modes
        mode_values = model_folds[param_name].mode()
        if not mode_values.empty:
            return mode_values.iloc[0] # Return the first mode if multiple
        return np.nan
    else: # int or float
        # Use median for numerical
        return model_folds[param_name].median()

