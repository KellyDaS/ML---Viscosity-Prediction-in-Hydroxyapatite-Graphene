# PATCH (SMOGN + BASELINE + SKILL + LOG-TARGET)
# ============================================================

import os, random
import numpy as np
import pandas as pd

from sklearn.metrics import (
    r2_score,
    mean_absolute_error,
    mean_squared_error,
    median_absolute_error
)

def calc_metrics(y_true, y_pred):
    return {
        "R2": float(r2_score(y_true, y_pred)),
        "MAE": float(mean_absolute_error(y_true, y_pred)),
        "RMSE": float(np.sqrt(mean_squared_error(y_true, y_pred))),
        "MedAE": float(median_absolute_error(y_true, y_pred)),
    }

def apply_smogn_train_only(X_train, y_train, seed=71, log_target=False):
    """
    SMOGN SOMENTE no treino (anti-contaminação).
    Correções:
      - reset_index(drop=True) para evitar erro de iloc out-of-bounds
      - opção log_target: aplica SMOGN no target transformado (log1p),
        coerente quando o modelo é treinado em log.
    """
    import smogn
    import warnings

    X_tr = X_train.copy().reset_index(drop=True)
    y_tr = y_train.copy().reset_index(drop=True)

    # se log_target, balanceia no espaço em que o modelo aprende
    y_for_smogn = np.log1p(y_tr.values) if log_target else y_tr.values

    df_tr = X_tr.copy()
    df_tr["VISCOSIDADE"] = y_for_smogn

    np.random.seed(seed)
    random.seed(seed)
    os.environ["PYTHONHASHSEED"] = str(seed)

    try:
        with warnings.catch_warnings():
            warnings.simplefilter("ignore")
            df_res = smogn.smoter(data=df_tr, y="VISCOSIDADE")

        y_res = df_res["VISCOSIDADE"].copy()
        X_res = df_res.drop(columns=["VISCOSIDADE"]).copy()
        return X_res, y_res

    except Exception as e:
        print(f"[SMOGN WARNING] Falhou neste fold (treino original). {type(e).__name__}: {e}")
        # retorna treino no mesmo espaço do target que o modelo usa
        return X_tr, pd.Series(y_for_smogn)

def run_cv_models(
    X, y, models_dict, cv, cv_name,
    groups=None, use_groups=False,
    use_smogn=False, smogn_seed=71,
    log_target=False
):
    """
    Executa CV para um conjunto de modelos e retorna:
      - df_folds: métricas por fold (treino e teste) + baseline + skill scores
      - df_summary: média±DP + IC95

    NOVO:
      - baseline no TESTE (média do treino): Baseline_MAE, Baseline_RMSE
      - skill relativo (sempre interpretável):
          Skill_MAE  = 1 - MAE_model/MAE_baseline
          Skill_RMSE = 1 - RMSE_model/RMSE_baseline
        (quanto maior, melhor; 0 = igual ao baseline; negativo = pior)
      - log_target:
          Treina em log1p(y), mas calcula métricas na escala original (expm1).
    """
    rows = []

    split_iter = cv.split(X, y, groups=groups) if use_groups else cv.split(X, y)

    for model_name, model in models_dict.items():
        fold = 0

        for train_idx, test_idx in split_iter:
            fold += 1

            X_train = X.iloc[train_idx].copy()
            X_test  = X.iloc[test_idx].copy()

            y_train_orig = y.iloc[train_idx].copy()   # escala original
            y_test_orig  = y.iloc[test_idx].copy()

           
            if use_smogn:
                X_train_fit, y_train_fit = apply_smogn_train_only(
                    X_train, y_train_orig, seed=smogn_seed, log_target=log_target
                )
            else:
                X_train_fit = X_train.copy()
                y_train_fit = np.log1p(y_train_orig.values) if log_target else y_train_orig.values

          #train
            
            model.fit(X_train_fit, y_train_fit)

            # ---------------------------
            # if log_target=True)
            # ---------------------------
            pred_train = model.predict(X_train)
            pred_test  = model.predict(X_test)

            if log_target:
                # volta para escala original
                pred_train = np.expm1(pred_train)
                pred_test  = np.expm1(pred_test)

                # proteção numérica: viscosidade não pode ser negativa
                pred_train = np.clip(pred_train, 0, None)
                pred_test  = np.clip(pred_test, 0, None)

           
            met_tr = calc_metrics(y_train_orig.values, pred_train)
            met_te = calc_metrics(y_test_orig.values, pred_test)

            # ---------------------------
            # Baseline
            # ---------------------------
            baseline_pred = np.full_like(y_test_orig.values, fill_value=y_train_orig.mean(), dtype=float)
            baseline_mae = float(mean_absolute_error(y_test_orig.values, baseline_pred))
            baseline_rmse = float(np.sqrt(mean_squared_error(y_test_orig.values, baseline_pred)))

            # Skill scores 
            
            skill_mae = float(1.0 - (met_te["MAE"] / baseline_mae)) if baseline_mae > 0 else np.nan
            skill_rmse = float(1.0 - (met_te["RMSE"] / baseline_rmse)) if baseline_rmse > 0 else np.nan

            rows.append({
                "CV": cv_name,
                "Modelo": model_name,
                "Fold": fold,

                "Train_R2": met_tr["R2"],
                "Train_MAE": met_tr["MAE"],
                "Train_RMSE": met_tr["RMSE"],
                "Train_MedAE": met_tr["MedAE"],

                "Test_R2": met_te["R2"],
                "Test_MAE": met_te["MAE"],
                "Test_RMSE": met_te["RMSE"],
                "Test_MedAE": met_te["MedAE"],

                "Baseline_MAE": baseline_mae,
                "Baseline_RMSE": baseline_rmse,
                "Skill_MAE": skill_mae,
                "Skill_RMSE": skill_rmse,

                "N_test": int(len(test_idx)),
                "N_groups_test": int(groups.iloc[test_idx].nunique()) if use_groups and groups is not None else np.nan,
                "LogTarget": bool(log_target)
            })

        # reset iterator
        split_iter = cv.split(X, y, groups=groups) if use_groups else cv.split(X, y)

    df_folds = pd.DataFrame(rows)

    # Summary
    df_summary = (
        df_folds.groupby(["CV", "Modelo", "LogTarget"])
        .agg(
            Train_R2_mean=("Train_R2","mean"), Train_R2_std=("Train_R2","std"),
            Test_R2_mean=("Test_R2","mean"),   Test_R2_std=("Test_R2","std"),

            Train_MAE_mean=("Train_MAE","mean"), Train_MAE_std=("Train_MAE","std"),
            Test_MAE_mean=("Test_MAE","mean"),   Test_MAE_std=("Test_MAE","std"),

            Train_RMSE_mean=("Train_RMSE","mean"), Train_RMSE_std=("Train_RMSE","std"),
            Test_RMSE_mean=("Test_RMSE","mean"),   Test_RMSE_std=("Test_RMSE","std"),

            Train_MedAE_mean=("Train_MedAE","mean"), Train_MedAE_std=("Train_MedAE","std"),
            Test_MedAE_mean=("Test_MedAE","mean"),   Test_MedAE_std=("Test_MedAE","std"),

            Baseline_MAE_mean=("Baseline_MAE","mean"), Baseline_MAE_std=("Baseline_MAE","std"),
            Baseline_RMSE_mean=("Baseline_RMSE","mean"), Baseline_RMSE_std=("Baseline_RMSE","std"),

            Skill_MAE_mean=("Skill_MAE","mean"), Skill_MAE_std=("Skill_MAE","std"),
            Skill_RMSE_mean=("Skill_RMSE","mean"), Skill_RMSE_std=("Skill_RMSE","std"),

            avg_groups_in_test=("N_groups_test","mean"),
        )
        .reset_index()
    )

    # IC95 
    n_folds = int(df_folds["Fold"].max())
    for metric in [
        ("Test_R2_mean","Test_R2_std","Test_R2_CI95"),
        ("Test_MAE_mean","Test_MAE_std","Test_MAE_CI95"),
        ("Test_RMSE_mean","Test_RMSE_std","Test_RMSE_CI95"),
        ("Skill_MAE_mean","Skill_MAE_std","Skill_MAE_CI95"),
        ("Skill_RMSE_mean","Skill_RMSE_std","Skill_RMSE_CI95"),
    ]:
        mean_col, std_col, ci_col = metric
        df_summary[ci_col] = 1.96 * df_summary[std_col] / np.sqrt(n_folds)

    return df_folds, df_summary

