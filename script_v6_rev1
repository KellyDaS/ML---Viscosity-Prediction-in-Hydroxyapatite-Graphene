# ── Descriptive statistics function ───────────────────────────
def describe_features(df, features, label, target=TARGET):
    cols = [c for c in features + [target] if c in df.columns]
    missing = [c for c in features + [target] if c not in df.columns]
    if missing:
        print(f"  Warning — {label}: missing columns → {missing}")

    stats = (
        df[cols]
        .describe(percentiles=[0.25, 0.50, 0.75])
        .T
        .rename(columns={
            "count": "N",
            "mean":  "Mean",
            "std":   "Std Dev",
            "min":   "Min",
            "25%":   "Q1 (25%)",
            "50%":   "Median",
            "75%":   "Q3 (75%)",
            "max":   "Max",
        })
    )
    stats.index.name = "Feature"
    stats["CV (%)"] = (stats["Std Dev"] / stats["Mean"].abs() * 100).round(2)
    return stats.round(4)

