        return dict(
            n_estimators=trial.suggest_int("n_estimators", 200, 1200),
            max_depth=trial.suggest_int("max_depth", 5, 40),
            min_samples_split=trial.suggest_int("min_samples_split", 2, 10),
            min_samples_leaf=trial.suggest_int("min_samples_leaf", 1, 6),
            max_features=trial.suggest_categorical("max_features", ["sqrt", "log2", None]),
        )

    if model_name == "HistGradientBoosting":
        return dict(
            max_iter=trial.suggest_int("max_iter", 200, 2000),
            learning_rate=trial.suggest_float("learning_rate", 1e-3, 0.2, log=True),
            max_depth=trial.suggest_int("max_depth", 3, 12),
            min_samples_leaf=trial.suggest_int("min_samples_leaf", 10, 80),
            l2_regularization=trial.suggest_float("l2_regularization", 1e-6, 1.0, log=True),
        )

    raise ValueError(f"Modelo não suportado no Optuna: {model_name}")


def build_model(model_name, base_seed=5, params=None):
    params = {} if params is None else params

    if model_name == "XGBoost":
        return XGBRegressor(random_state=base_seed, n_jobs=-1, **params)

    if model_name == "LightGBM":
        return LGBMRegressor(random_state=base_seed, **params)

    if model_name == "CatBoost":
        return CatBoostRegressor(
            random_state=base_seed,
            silent=True,
            **params
        )

    if model_name == "RandomForest":
        return RandomForestRegressor(random_state=base_seed, **params)

    if model_name == "HistGradientBoosting":
        return HistGradientBoostingRegressor(random_state=base_seed, **params)

    raise ValueError(f"Modelo não suportado: {model_name}")

# ------------------------------------------------------------

def tune_with_optuna(
    model_name,
    X_tr, y_tr, groups_tr,
    n_trials=40,
    inner_splits=3,
    use_smogn=True,
    smogn_seed=71,
    log_target=True,
    base_seed=5
):
    n_groups_tr = groups_tr.nunique()
    inner_splits = min(inner_splits, n_groups_tr)
    if inner_splits < 2:
        # Sem CV interno possível: retorna "sem tuning"
        return {}

    gkf_inner = GroupKFold(n_splits=inner_splits)

    def objective(trial):
        params = suggest_params(trial, model_name)
        model = build_model(model_name, base_seed=base_seed, params=params)

        rmses = []
        for tr_idx, va_idx in gkf_inner.split(X_tr, y_tr, groups=groups_tr):
            X_train_i = X_tr.iloc[tr_idx].copy()
            y_train_i = y_tr.iloc[tr_idx].copy()
            X_val_i   = X_tr.iloc[va_idx].copy()
            y_val_i   = y_tr.iloc[va_idx].copy()

            # SMOGN somente no treino do fold interno
            if use_smogn:
                X_fit, y_fit = apply_smogn_train_only(
                    X_train_i, y_train_i, seed=smogn_seed, log_target=log_target
                )
            else:
                X_fit = X_train_i.copy()
                y_fit = np.log1p(y_train_i.values) if log_target else y_train_i.values

            model_i = clone(model)
            model_i.fit(X_fit, y_fit)

            pred_val = model_i.predict(X_val_i)
            if log_target:
                pred_val = np.expm1(pred_val)
                pred_val = np.clip(pred_val, 0, None)

            rmse = float(np.sqrt(mean_squared_error(y_val_i.values, pred_val)))
            rmses.append(rmse)

        return float(np.mean(rmses))

    study = optuna.create_study(direction="minimize")
    study.optimize(objective, n_trials=n_trials, show_progress_bar=False)

    return study.best_params

# ------------------------------------------------------------
# 4) Nested CV  (GroupKFold(5)) — ST3 
# ------------------------------------------------------------
def run_st3_nested_groupkfold(
    X, y, groups,
    model_names=("LightGBM","XGBoost","CatBoost","HistGradientBoosting","RandomForest"),
    outer_splits=5,
    inner_splits=3,
    n_trials=40,
    use_smogn=True,
    smogn_seed=71,
    log_target=True,
    base_seed=5,
    cv_label="ST3_NestedOptuna_SMOGN_GroupKFold"
):
    outer_splits = min(outer_splits, groups.nunique())
    gkf_outer = GroupKFold(n_splits=outer_splits)

    rows = []
    best_params_rows = []

    for model_name in model_names:
        fold = 0
        for tr_idx, te_idx in gkf_outer.split(X, y, groups=groups):
            fold += 1

            X_tr = X.iloc[tr_idx].copy()
            y_tr = y.iloc[tr_idx].copy()
            g_tr = groups.iloc[tr_idx].copy()

            X_te = X.iloc[te_idx].copy()
            y_te = y.iloc[te_idx].copy()
            g_te = groups.iloc[te_idx].copy()

            # ---- tuning 
            best_params = tune_with_optuna(
                model_name,
                X_tr, y_tr, g_tr,
                n_trials=n_trials,
                inner_splits=inner_splits,
                use_smogn=use_smogn,
                smogn_seed=smogn_seed,
                log_target=log_target,
                base_seed=base_seed
            )

            best_params_rows.append({
                "CV": cv_label,
                "Modelo": model_name,
                "Fold": fold,
                "BestParams": str(best_params),
                "N_groups_train": int(g_tr.nunique()),
                "N_groups_test": int(g_te.nunique())
            })

            # ---- fit 
            model = build_model(model_name, base_seed=base_seed, params=best_params)

            if use_smogn:
                X_fit, y_fit = apply_smogn_train_only(
                    X_tr, y_tr, seed=smogn_seed, log_target=log_target
                )
            else:
                X_fit = X_tr.copy()
                y_fit = np.log1p(y_tr.values) if log_target else y_tr.values

            model.fit(X_fit, y_fit)

            # ---- pred
            pred_tr = model.predict(X_tr)
            pred_te = model.predict(X_te)

            if log_target:
                pred_tr = np.expm1(pred_tr); pred_tr = np.clip(pred_tr, 0, None)
                pred_te = np.expm1(pred_te); pred_te = np.clip(pred_te, 0, None)

            met_tr = calc_metrics(y_tr.values, pred_tr)
            met_te = calc_metrics(y_te.values, pred_te)

            # baseline 
            baseline_pred = np.full_like(y_te.values, fill_value=y_tr.mean(), dtype=float)
            baseline_mae = float(mean_absolute_error(y_te.values, baseline_pred))
            baseline_rmse = float(np.sqrt(mean_squared_error(y_te.values, baseline_pred)))

            skill_mae = float(1.0 - (met_te["MAE"]/baseline_mae)) if baseline_mae > 0 else np.nan
            skill_rmse = float(1.0 - (met_te["RMSE"]/baseline_rmse)) if baseline_rmse > 0 else np.nan

            rows.append({
                "CV": cv_label,
                "Modelo": model_name,
                "Fold": fold,
                "Train_R2": met_tr["R2"],
                "Train_MAE": met_tr["MAE"],
                "Train_RMSE": met_tr["RMSE"],
                "Train_MedAE": met_tr["MedAE"],
                "Test_R2": met_te["R2"],
                "Test_MAE": met_te["MAE"],
                "Test_RMSE": met_te["RMSE"],
                "Test_MedAE": met_te["MedAE"],
                "Baseline_MAE": baseline_mae,
                "Baseline_RMSE": baseline_rmse,
                "Skill_MAE": skill_mae,
                "Skill_RMSE": skill_rmse,
                "N_test": int(len(te_idx)),
                "N_groups_test": int(g_te.nunique()),
                "LogTarget": bool(log_target),
                "UsedSMOGN": bool(use_smogn),
                "OptunaTrials": int(n_trials),
                "InnerSplits": int(min(inner_splits, g_tr.nunique()))
            })

    df_folds = pd.DataFrame(rows)
    df_bestparams = pd.DataFrame(best_params_rows)

    # Summary (média±DP)
    df_summary = (
        df_folds.groupby(["CV","Modelo","LogTarget","UsedSMOGN","OptunaTrials","InnerSplits"])
        .agg(
            Test_R2_mean=("Test_R2","mean"), Test_R2_std=("Test_R2","std"),
            Test_MAE_mean=("Test_MAE","mean"), Test_MAE_std=("Test_MAE","std"),
            Test_RMSE_mean=("Test_RMSE","mean"), Test_RMSE_std=("Test_RMSE","std"),
            Test_MedAE_mean=("Test_MedAE","mean"), Test_MedAE_std=("Test_MedAE","std"),
            Skill_MAE_mean=("Skill_MAE","mean"), Skill_MAE_std=("Skill_MAE","std"),
            Skill_RMSE_mean=("Skill_RMSE","mean"), Skill_RMSE_std=("Skill_RMSE","std"),
            Baseline_MAE_mean=("Baseline_MAE","mean"),
            Baseline_RMSE_mean=("Baseline_RMSE","mean"),
        )
        .reset_index()
    )

    n_folds = df_folds["Fold"].max()
    for metric in [("Test_MAE_mean","Test_MAE_std","Test_MAE_CI95"),
                   ("Test_RMSE_mean","Test_RMSE_std","Test_RMSE_CI95"),
                   ("Skill_MAE_mean","Skill_MAE_std","Skill_MAE_CI95"),
                   ("Skill_RMSE_mean","Skill_RMSE_std","Skill_RMSE_CI95")]:
        mean_col, std_col, ci_col = metric
        df_summary[ci_col] = 1.96 * df_summary[std_col] / np.sqrt(n_folds)

    return df_folds, df_summary, df_bestparams

