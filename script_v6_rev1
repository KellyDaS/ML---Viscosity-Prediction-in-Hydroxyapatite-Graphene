SHEAR  = "TAXA DE CISALHAMENTO"
TARGET = "VISCOSIDADE"

MODEL_ORDER = ["LightGBM", "XGBoost", "CatBoost", "HistGradientBoosting", "RandomForest"]
LEGEND_MAP = {
    "LightGBM": "LGBM",
    "XGBoost": "XGBoost",
    "CatBoost": "CatBoost",
    "HistGradientBoosting": "HGBT",
    "RandomForest": "RF",
}

N_GRID = 600
USE_HB_SMOOTH = True
GAMMA_MIN_FIT = 0.5

# percentis p/ limites globais (evita outlier dominar)
P_LOW, P_HIGH = 0.5, 99.5
MARGIN = 0.08  # 8% de margem

# ============================================================
# HB smoothing 
# ============================================================
def hb_viscosity(gamma, tau0, K, n):
    return (tau0 + K*(gamma**n)) / gamma

def fit_hb_to_ml_curve_logvisc(gamma, visc_pred, gamma_min_fit=0.5):
    gamma = np.asarray(gamma, float)
    visc_pred = np.asarray(visc_pred, float)

    m = np.isfinite(gamma) & np.isfinite(visc_pred) & (gamma > 0) & (visc_pred > 0) & (gamma >= gamma_min_fit)
    g = gamma[m]
    y = visc_pred[m]

    if len(g) < 8:
        m = np.isfinite(gamma) & np.isfinite(visc_pred) & (gamma > 0) & (visc_pred > 0)
        g = gamma[m]
        y = visc_pred[m]

    logy = np.log(np.clip(y, 1e-12, None))

    bounds = ([0.0, 0.0, 0.0], [np.inf, np.inf, 2.0])
    p0 = [0.0, 1.0, 0.6]

    def model_log_eta(gamma, tau0, K, n):
        eta = hb_viscosity(gamma, tau0, K, n)
        eta = np.clip(eta, 1e-12, None)
        return np.log(eta)

    popt, _ = curve_fit(model_log_eta, g, logy, p0=p0, bounds=bounds, maxfev=50000)
    return tuple(map(float, popt))

# ============================================================
#  ST4  (linear)


def predict_curve_ST4(dfc, model, shear_grid):
    row0 = dfc.iloc[0]
    Xg = pd.DataFrame({
        SHEAR: shear_grid,
        "tau_0": row0["tau_0"],
        "K": row0["K"],
        "n": row0["n"],
        "HA_porcentagem": row0["HA_porcentagem"],
        "rGO_porcentagem": row0["rGO_porcentagem"],
    })
    y_pred = np.expm1(model.predict(Xg))
    return np.clip(y_pred, 0, None)

# ============================================================
for m in MODEL_ORDER:
    if m not in trained:
        raise ValueError(f"Modelo '{m}' não está em trained. Disponíveis: {list(trained.keys())}")

req_cols = [GROUP, SHEAR, TARGET, "tau_0", "K", "n", "HA_porcentagem", "rGO_porcentagem"]
missing_cols = [c for c in req_cols if c not in df_val_measured.columns]
if missing_cols:
    raise ValueError(f"df_val_measured faltando colunas: {missing_cols}")

# ============================================================
# s (xlim/ylim) 
# ============================================================
comps = sorted(df_val_measured[GROUP].unique().tolist())

all_x = []
all_y = []

for comp in comps:
    dfc = df_val_measured[df_val_measured[GROUP] == comp].copy().sort_values(SHEAR)
    x = dfc[SHEAR].values.astype(float)
    y = dfc[TARGET].values.astype(float)

    all_x.append(x)
    all_y.append(y)

    x_min = float(np.nanmin(x))
    x_max = float(np.nanmax(x))
    shear_grid = np.linspace(x_min, x_max, N_GRID)

    for model_name in MODEL_ORDER:
        y_ml = predict_curve_ST4(dfc, trained[model_name], shear_grid)
        if USE_HB_SMOOTH:
            try:
                tau0_ml, K_ml, n_ml = fit_hb_to_ml_curve_logvisc(shear_grid, y_ml, gamma_min_fit=GAMMA_MIN_FIT)
                y_ml = hb_viscosity(shear_grid, tau0_ml, K_ml, n_ml)
            except Exception:
                pass
        all_x.append(shear_grid)
        all_y.append(y_ml)

all_x = np.concatenate(all_x)
all_y = np.concatenate(all_y)

# remove não-finito
mx = np.isfinite(all_x)
my = np.isfinite(all_y)
all_x = all_x[mx]
all_y = all_y[my]


x_lo, x_hi = np.percentile(all_x, [P_LOW, P_HIGH])
y_lo, y_hi = np.percentile(all_y, [P_LOW, P_HIGH])


x_pad = (x_hi - x_lo) * MARGIN
y_pad = (y_hi - y_lo) * MARGIN

xlim = (max(0, x_lo - x_pad), x_hi + x_pad)
ylim = (max(0, y_lo - y_pad), y_hi + y_pad)

print("xlim global:", xlim)
print("ylim global:", ylim)

# ============================================================
# 2) Plot grid 
# ============================================================
n = len(comps)
ncols = 3
nrows = math.ceil(n / ncols)

fig, axes = plt.subplots(nrows, ncols, figsize=(5.7*ncols, 4.4*nrows))
axes = np.array(axes).reshape(nrows, ncols)

for idx, comp in enumerate(comps):
    r = idx // ncols
    c = idx % ncols
    ax = axes[r, c]

    dfc = df_val_measured[df_val_measured[GROUP] == comp].copy().sort_values(SHEAR)

    x_min = float(dfc[SHEAR].min())
    x_max = float(dfc[SHEAR].max())
    shear_grid = np.linspace(x_min, x_max, N_GRID)

    # Experimental como triângulos
    ax.scatter(dfc[SHEAR], dfc[TARGET], marker="^", color="k", label="Viscosity", zorder=5, s=28)

    for model_name in MODEL_ORDER:
        y_ml = predict_curve_ST4(dfc, trained[model_name], shear_grid)

        if USE_HB_SMOOTH:
            try:
                tau0_ml, K_ml, n_ml = fit_hb_to_ml_curve_logvisc(shear_grid, y_ml, gamma_min_fit=GAMMA_MIN_FIT)
                y_plot = hb_viscosity(shear_grid, tau0_ml, K_ml, n_ml)
            except Exception:
                y_plot = y_ml
        else:
            y_plot = y_ml

        ax.plot(shear_grid, y_plot, linewidth=1.6, label=LEGEND_MAP.get(model_name, model_name))

    ax.set_title(comp, fontsize=10)
    ax.set_xlabel("Shear rate (s$^{-1}$)")
    ax.set_ylabel("Viscosity (Pa.s)")
    ax.grid(True, alpha=0.35)

  
    ax.set_xlim(*xlim)
    ax.set_ylim(*ylim)

    if idx == 0:
        ax.legend(loc="upper right", fontsize=8, frameon=True)


for j in range(n, nrows*ncols):
    r = j // ncols
