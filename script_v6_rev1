def _norm(s: str) -> str:
    s = str(s).strip()
    s = (s.replace("Ç","C").replace("ç","c")
           .replace("Ã","A").replace("ã","a")
           .replace("Á","A").replace("á","a")
           .replace("Â","A").replace("â","a")
           .replace("É","E").replace("é","e")
           .replace("Ê","E").replace("ê","e")
           .replace("Í","I").replace("í","i")
           .replace("Ó","O").replace("ó","o")
           .replace("Ô","O").replace("ô","o")
           .replace("Õ","O").replace("õ","o")
           .replace("Ú","U").replace("ú","u"))
    s = re.sub(r"\s+", " ", s)
    return s.upper()

def standardize_df(df: pd.DataFrame) -> pd.DataFrame:
    df = df.rename(columns={c: _norm(c) for c in df.columns})

   
    required = {
        "HA": ["HA", "HAP"],
        "RGO": ["RGO"],
        "TAXA_DE_CISALHAMENTO": ["TAXA DE CISALHAMENTO", "TAXA_DE_CISALHAMENTO", "SHEAR RATE", "SHEAR_RATE"],
        "VISCOSIDADE": ["VISCOSIDADE", "VISCOSITY"]
    }

    found = {}
    for std, cands in required.items():
        col = None
        for cand in cands:
            cand_norm = _norm(cand)
            if cand_norm in df.columns:
                col = cand_norm
                break
        found[std] = col

    missing = [k for k,v in found.items() if v is None]
    if missing:
        raise ValueError(f"Colunas essenciais ausentes: {missing}. Colunas atuais: {list(df.columns)}")

    df = df.rename(columns={
        found["HA"]: "HA",
        found["RGO"]: "rGO",  # no seu dataset você usa 'rGO' (minúsculo r)
        found["TAXA_DE_CISALHAMENTO"]: "TAXA DE CISALHAMENTO",
        found["VISCOSIDADE"]: "VISCOSIDADE",
    })

    return df

