# ── 2. Helper Functions ───────────────────────────────────────

def format_value(value, ptype):
    """Formats a value based on its type for display."""
    if pd.isna(value):
        return ""
    if ptype == "int":
        return int(round(value))
    elif ptype == "float":
        return f"{value:.5f}".rstrip('0').rstrip('.') # Keep up to 5 decimal places, remove trailing zeros
    elif ptype == "categorical":
        return str(value)
    return str(value)

def load_and_process_optuna_folds(file_path, sheet_name="Folds"): # Changed default sheet_name to "Folds"
    """
    Loads Optuna results from an Excel file, processes the 'BestParams' column,
    and returns a DataFrame with parameters expanded.
    """
    try:
        df = pd.read_excel(file_path, sheet_name=sheet_name)
        df.columns = df.columns.str.strip() # Strip whitespace from column names

        if 'BestParams' not in df.columns:
            print(f"Error processing {file_path} (sheet '{sheet_name}'): \"['BestParams'] not in index\"")
            return pd.DataFrame()

        # Convert string representation of dict to actual dict
        def parse_best_params(param_str):
            try:
                return ast.literal_eval(param_str)
            except (ValueError, SyntaxError) as e:
                print(f"Warning: Could not parse BestParams string '{param_str[:100]}...' in {file_path}: {e}")
                return {} # Return empty dict on error

        df['BestParams_Dict'] = df['BestParams'].apply(parse_best_params)

        # Rename 'Modelo' to 'Model' for consistency if it exists
        if 'Modelo' in df.columns:
            df = df.rename(columns={'Modelo': 'Model'})

        # Use 'Model' column for grouping if it exists, otherwise 'Modelo'
        model_col = 'Model' if 'Model' in df.columns else 'Modelo' if 'Modelo' in df.columns else None

        if model_col:
            # Aggregate parameters by model and fold
            processed_data = []
            for (model_name, fold), group in df.groupby([model_col, 'Fold']):
                if not group.empty:
                    # Combine all params from the fold into one dict
                    combined_params = {}
                    for p_dict in group['BestParams_Dict']:
                        combined_params.update(p_dict)

                    row = {
                        model_col: model_name,
                        'Fold': fold,
                        **combined_params
                    }
                    processed_data.append(row)
            df_processed = pd.DataFrame(processed_data)
        else:
            # Fallback if no model column is found, just expand params
            df_processed = pd.concat([df.drop(columns=['BestParams', 'BestParams_Dict']), pd.json_normalize(df['BestParams_Dict'])], axis=1)

        return df_processed
    except Exception as e:
        print(f"Error loading or processing {file_path}: {e}")
        return pd.DataFrame()

