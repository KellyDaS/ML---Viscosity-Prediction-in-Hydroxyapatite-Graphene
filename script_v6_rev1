            "subsample": trial.suggest_float("subsample", 0.6, 1.0),
            "colsample_bytree": trial.suggest_float("colsample_bytree", 0.6, 1.0),
            "reg_lambda": trial.suggest_float("reg_lambda", 1e-4, 10.0, log=True),
            "reg_alpha": trial.suggest_float("reg_alpha", 1e-6, 1.0, log=True),
            **LGBM_SILENT
        }

    if model_name == "CatBoost":
        return {
            "iterations": trial.suggest_int("iterations", 400, 2000),
            "learning_rate": trial.suggest_float("learning_rate", 0.005, 0.2, log=True),
            "depth": trial.suggest_int("depth", 3, 10),
            "l2_leaf_reg": trial.suggest_float("l2_leaf_reg", 1e-3, 20.0, log=True),
            "random_strength": trial.suggest_float("random_strength", 1e-6, 10.0, log=True),
            "bagging_temperature": trial.suggest_float("bagging_temperature", 0.0, 1.0),
            "loss_function": "RMSE",
            "verbose": False,
        }

    if model_name == "RandomForest":
        return {
            "n_estimators": trial.suggest_int("n_estimators", 300, 1200),
            "max_depth": trial.suggest_int("max_depth", 3, 40),
            "min_samples_split": trial.suggest_int("min_samples_split", 2, 12),
            "min_samples_leaf": trial.suggest_int("min_samples_leaf", 1, 8),
            "max_features": trial.suggest_categorical("max_features", ["sqrt", "log2", None]),
            "bootstrap": trial.suggest_categorical("bootstrap", [True, False]),
        }

    if model_name == "HistGradientBoosting":
        return {
            "learning_rate": trial.suggest_float("learning_rate", 0.01, 0.2, log=True),
            "max_depth": trial.suggest_int("max_depth", 2, 16),
            "max_iter": trial.suggest_int("max_iter", 200, 1500),
            "min_samples_leaf": trial.suggest_int("min_samples_leaf", 5, 60),
            "l2_regularization": trial.suggest_float("l2_regularization", 1e-6, 1.0, log=True),
        }

    raise ValueError(f"Modelo não suportado: {model_name}")

def build_model(model_name, params):
    if model_name == "XGBoost":
        return XGBRegressor(
            random_state=BASE_SEED,
            objective="reg:squarederror",
            n_jobs=-1,
            **params
        )
    if model_name == "LightGBM":
        return LGBMRegressor(
            random_state=BASE_SEED,
            n_jobs=-1,
            **params
        )
    if model_name == "CatBoost":
        return CatBoostRegressor(
            random_seed=BASE_SEED,
            **params
        )
    if model_name == "RandomForest":
        return RandomForestRegressor(
            random_state=BASE_SEED,
            n_jobs=-1,
            **params
        )
    if model_name == "HistGradientBoosting":
        return HistGradientBoostingRegressor(
            random_state=BASE_SEED,
            **params
        )
    raise ValueError(f"Modelo não reconhecido: {model_name}")

# -------------------------
# 4) LOOP 
# -------------------------
models_to_optimize = ["CatBoost", "XGBoost", "RandomForest", "HistGradientBoosting", "LightGBM"]

best_params_ST2 = {}
best_models_ST2 = {}
trials_rows = []

for model_name in models_to_optimize:

    print(f"\n=== Optuna ST2: {model_name} ===")

