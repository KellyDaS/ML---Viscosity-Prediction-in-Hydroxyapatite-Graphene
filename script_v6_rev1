import numpy as np
import pandas as pd
from sklearn.metrics import r2_score, mean_absolute_error, mean_squared_error, median_absolute_error

# ==========================
# CONFIG
# ==========================
OUT_XLSX = "ExternalPoints_Predictions_and_Errors_ST4.xlsx"

GROUP  = "HA_rGO"
SHEAR  = "TAXA DE CISALHAMENTO"
TARGET = "VISCOSIDADE"

FEATURES_ST4 = [SHEAR, "tau_0", "K", "n", "HA_porcentagem", "rGO_porcentagem"]


if "MODEL_ORDER" not in globals():
    MODEL_ORDER = list(trained.keys())


missing = [c for c in [GROUP, SHEAR, TARGET] + FEATURES_ST4 if c not in df_val_measured.columns]
if missing:
    raise ValueError(f"df_val_measured faltando colunas: {missing}")

for m in MODEL_ORDER:
    if m not in trained:
        raise ValueError(f"Modelo '{m}' não encontrado em trained. Disponíveis: {list(trained.keys())}")

# ==========================
# 1) Pred
# ==========================
df_points = df_val_measured[[GROUP, SHEAR, TARGET] + [c for c in FEATURES_ST4 if c not in [SHEAR]]].copy()
X_val = df_val_measured[FEATURES_ST4].copy()
y_true = df_val_measured[TARGET].values.astype(float)

# baseline 
baseline_pred = np.full_like(y_true, fill_value=np.mean(y_true), dtype=float)
df_points["Pred_BaselineMean"] = baseline_pred


def point_errors(y, yhat):
    err = yhat - y
    abs_err = np.abs(err)
    sq_err = err**2
    # evita divisão por zero em APE
    ape = np.where(y > 0, abs_err / y * 100.0, np.nan)
    return err, abs_err, sq_err, ape

# baseline errors
e, ae, se, ape = point_errors(y_true, baseline_pred)
df_points["Err_Baseline"] = e
df_points["AbsErr_Baseline"] = ae
df_points["SqErr_Baseline"] = se
df_points["APEpct_Baseline"] = ape

# pred
for model_name in MODEL_ORDER:
    model = trained[model_name]

    pred = np.expm1(model.predict(X_val))  # treinado em log1p(y)
    pred = np.clip(pred, 0, None)

    df_points[f"Pred_{model_name}"] = pred

    e, ae, se, ape = point_errors(y_true, pred)
    df_points[f"Err_{model_name}"] = e
    df_points[f"AbsErr_{model_name}"] = ae
    df_points[f"SqErr_{model_name}"] = se
    df_points[f"APEpct_{model_name}"] = ape


def metrics(y, yhat):
    return {
        "R2": float(r2_score(y, yhat)),
        "MAE": float(mean_absolute_error(y, yhat)),
        "RMSE": float(np.sqrt(mean_squared_error(y, yhat))),
        "MedAE": float(median_absolute_error(y, yhat)),
        "MAPE%": float(np.nanmean(np.where(y > 0, np.abs(yhat - y) / y * 100.0, np.nan))),
    }

rows = []

# baseline
rows.append({
    "Model": "BaselineMean",
    **metrics(y_true, baseline_pred),
    "n_points": int(len(y_true)),
    "n_compositions": int(df_val_measured[GROUP].nunique())
})

for model_name in MODEL_ORDER:
    yhat = df_points[f"Pred_{model_name}"].values.astype(float)
    rows.append({
        "Model": model_name,
        **metrics(y_true, yhat),
        "n_points": int(len(y_true)),
        "n_compositions": int(df_val_measured[GROUP].nunique())
    })

df_summary = pd.DataFrame(rows).sort_values("RMSE", ascending=True).reset_index(drop=True)


bycomp_rows = []

for comp, d in df_points.groupby(GROUP):
    y_c = d[TARGET].values.astype(float)

    # baseline
    yhat_b = d["Pred_BaselineMean"].values.astype(float)
    bycomp_rows.append({"HA_rGO": comp, "Model": "BaselineMean", **metrics(y_c, yhat_b), "n_points": int(len(d))})

    # modelos
    for model_name in MODEL_ORDER:
        yhat_c = d[f"Pred_{model_name}"].values.astype(float)
        bycomp_rows.append({"HA_rGO": comp, "Model": model_name, **metrics(y_c, yhat_c), "n_points": int(len(d))})

df_bycomp = pd.DataFrame(bycomp_rows).sort_values(["HA_rGO", "RMSE"], ascending=[True, True]).reset_index(drop=True)

# ==========================
#  Excel
# ==========================
with pd.ExcelWriter(OUT_XLSX, engine="openpyxl") as w:
    df_points.to_excel(w, sheet_name="PerPoint_Preds_Errors", index=False)
    df_summary.to_excel(w, sheet_name="Summary_Overall", index=False)
    df_bycomp.to_excel(w, sheet_name="Summary_ByComposition", index=False)

print("✓ Excel salvo:", OUT_XLSX)
